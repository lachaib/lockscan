{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "maxSize": 2000000,
    "includes": [
      "**/*",
      "!**/build",
      "!!**/dist",
      "!!**/node_modules",
      "!!**/tests/fixtures",
      "!!**/.claude"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  }
}
